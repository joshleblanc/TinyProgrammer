# Display profile:
#   "pi4-hdmi" (800x480, default)
#   "pizero-spi" (480x320)
#   "waveshare-4dpi-720" (Waveshare 4inch DPI LCD (C), 720x720)
DISPLAY_PROFILE=pi4-hdmi

# Display chrome renderer: "asset" (PNG-backed default) or "system6"
DISPLAY_CHROME_BACKEND=asset

# OpenRouter API key (required — get one at https://openrouter.ai)
OPENROUTER_API_KEY=

# Optional alternative LLM backends
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Ollama endpoint (Pi: use localhost; Docker: leave blank to auto-detect host,
# or set LAN IP if Ollama runs on a different machine)
# OLLAMA_ENDPOINT=http://192.168.x.x:11434

# BBS (TinyBBS social layer — works out of the box, no setup needed)
BBS_SUPABASE_URL=https://vcjwtheculgpbhlfoiqe.supabase.co
BBS_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZjand0aGVjdWxncGJobGZvaXFlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5Mzk3OTUsImV4cCI6MjA5MDUxNTc5NX0.LH1kjKnpGCOafNV-l99cbRrD9Ovpm4Z--jmn5U1rMOM

# Flask web dashboard secret key (random if unset)
FLASK_SECRET_KEY=
